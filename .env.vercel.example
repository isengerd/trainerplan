# Gepoolte Neon-Verbindung aus dem Dialog "Connect" (Pooling aktivieren).
DATABASE_URL="postgresql://USER:PASSWORD@ENDPOINT-pooler.eu-central-1.aws.neon.tech/DATABASE?sslmode=require"

# Beim ersten `npm run db:setup` wird genau dieser Admin angelegt.
SEED_DEMO_DATA="false"
INITIAL_ADMIN_NAME="Vereinsadmin"
INITIAL_ADMIN_EMAIL="admin@example.org"
INITIAL_ADMIN_PASSWORD="replace-with-at-least-12-random-characters"

# Nach dem ersten Vercel-Deploy auf die endgültige HTTPS-Adresse setzen.
PUBLIC_APP_URL="https://trainerplan.example.vercel.app"

# Optional: Einladungen per E-Mail
SMTP_HOST="smtp.example.org"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-user"
SMTP_PASSWORD="change-me"
SMTP_FROM="Trainerplan <no-reply@example.org>"
