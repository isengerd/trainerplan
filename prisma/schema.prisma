generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  trainer
  player
}

enum AttendanceValue {
  yes
  no
  maybe
}

model User {
  id                      String                  @id
  name                    String
  email                   String                  @unique
  passwordHash            String
  role                    Role
  position                String
  number                  Int?
  phone                   String                  @default("")
  birthday                DateTime?               @db.Date
  ageGroup                String                  @default("F-Jugend")
  avatar                  String?                 @db.Text
  groupId                 String?
  dribblingRating         Int                     @default(0)
  shootingRating          Int                     @default(0)
  passingRating           Int                     @default(0)
  internalTeam            String?
  group                   TeamGroup?              @relation(fields: [groupId], references: [id], onDelete: SetNull)
  invitations             Invitation[]            @relation("InvitationCreator")
  emailChangeRequests     EmailChangeRequest[]
  responses               AttendanceResponse[]
  sessions                ApiSession[]
  coachedTournamentSquads TournamentSquad[]       @relation("TournamentSquadTrainer")
  tournamentAssignments   TournamentSquadPlayer[]
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([groupId])
}

model EmailChangeRequest {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  newEmail  String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([newEmail])
}

model AgeGroup {
  id        String   @id
  name      String   @unique
  ageRange  String
  sortOrder Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamGroup {
  id          String       @id @default(cuid())
  name        String
  description String       @default("")
  color       String       @default("#45d875")
  users       User[]
  invitations Invitation[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Invitation {
  id          String     @id @default(cuid())
  tokenHash   String     @unique
  email       String
  name        String     @default("")
  role        Role
  ageGroup    String     @default("F-Jugend")
  groupId     String?
  group       TeamGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  invitedById String
  invitedBy   User       @relation("InvitationCreator", fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime   @default(now())

  @@index([email])
  @@index([groupId])
  @@index([invitedById])
}

model ClubEvent {
  id                    String                  @id
  type                  String
  title                 String
  date                  DateTime                @db.Date
  startTime             String
  endTime               String
  location              String
  address               String?
  meetingTime           String
  description           String                  @db.Text
  trainerNote           String?                 @db.Text
  weather               Json?
  maxParticipants       Int
  responses             AttendanceResponse[]
  tournamentSquads      TournamentSquad[]
  tournamentAssignments TournamentSquadPlayer[]
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
}

model TournamentSquad {
  id        String                  @id @default(cuid())
  eventId   String
  event     ClubEvent               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  trainerId String?
  trainer   User?                   @relation("TournamentSquadTrainer", fields: [trainerId], references: [id], onDelete: SetNull)
  players   TournamentSquadPlayer[]
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@index([eventId])
  @@index([trainerId])
}

model TournamentSquadPlayer {
  squadId   String
  eventId   String
  playerId  String
  squad     TournamentSquad @relation(fields: [squadId], references: [id], onDelete: Cascade)
  event     ClubEvent       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player    User            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@id([squadId, playerId])
  @@unique([eventId, playerId])
  @@index([playerId])
}

model AttendanceResponse {
  eventId   String
  userId    String
  value     AttendanceValue
  event     ClubEvent       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime        @updatedAt

  @@id([eventId, userId])
}

model ExerciseRecord {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppConfig {
  id        String   @id @default("default")
  settings  Json
  plans     Json
  templates Json
  planMeta  Json
  updatedAt DateTime @updatedAt
}

model ApiSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
